<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>ツール on firebirdテックトーク</title><link>https://firebird-techtalktech.com/categories/%E3%83%84%E3%83%BC%E3%83%AB/</link><description>Recent content in ツール on firebirdテックトーク</description><generator>Hugo -- gohugo.io</generator><language>ja</language><copyright>トミー</copyright><atom:link href="https://firebird-techtalktech.com/categories/%E3%83%84%E3%83%BC%E3%83%AB/index.xml" rel="self" type="application/rss+xml"/><item><title>Base64 エンコード・デコード</title><link>https://firebird-techtalktech.com/tools/base64/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/base64/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="base64-エンコードデコード"&gt;Base64 エンコード・デコード
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="tool-row"&gt;
&lt;button class="btn-primary" onclick="encode()"&gt;エンコード →&lt;/button&gt;
&lt;button onclick="decode()"&gt;← デコード&lt;/button&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;button onclick="copyOutput()"&gt;コピー&lt;/button&gt;
&lt;/div&gt;
&lt;div class="editor-row"&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;入力&lt;/label&gt;
&lt;textarea id="input" placeholder="変換するテキストを入力" spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;出力&lt;/label&gt;
&lt;textarea id="output" readonly spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;p id="status"&gt;&lt;/p&gt;
&lt;p id="copy-msg" style="color:green;display:none"&gt;コピーしました！&lt;/p&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function encode() {
const input = document.getElementById('input').value;
const status = document.getElementById('status');
try {
document.getElementById('output').value = btoa(unescape(encodeURIComponent(input)));
status.style.color = 'green';
status.textContent = '✅ エンコード完了';
} catch(e) {
status.style.color = 'red';
status.textContent = '❌ エラー: ' + e.message;
}
}
function decode() {
const input = document.getElementById('input').value.trim();
const status = document.getElementById('status');
try {
document.getElementById('output').value = decodeURIComponent(escape(atob(input)));
status.style.color = 'green';
status.textContent = '✅ デコード完了';
} catch(e) {
status.style.color = 'red';
status.textContent = '❌ 無効なBase64文字列です';
}
}
function clearAll() {
document.getElementById('input').value = '';
document.getElementById('output').value = '';
document.getElementById('status').textContent = '';
}
function copyOutput() {
const v = document.getElementById('output').value;
if (!v) return;
navigator.clipboard.writeText(v).then(() =&gt; {
const msg = document.getElementById('copy-msg');
msg.style.display = 'block';
setTimeout(() =&gt; msg.style.display = 'none', 2000);
});
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 900px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.tool-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.editor-row { display: flex; gap: 1rem; }
.editor-col { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 260px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
#status { font-size: 0.9rem; min-height: 1.2em; }
@media (max-width: 600px) { .editor-row { flex-direction: column; } }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;入力欄にテキストを貼り付ける&lt;/li&gt;
&lt;li&gt;「エンコード →」でBase64形式に変換&lt;/li&gt;
&lt;li&gt;「← デコード」でBase64から元のテキストに復元&lt;/li&gt;
&lt;li&gt;「コピー」で出力をクリップボードにコピー&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="用途例"&gt;用途例
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;APIキーやトークンの確認&lt;/li&gt;
&lt;li&gt;データURIスキームの生成&lt;/li&gt;
&lt;li&gt;Basic認証ヘッダーの確認（&lt;code&gt;user:pass&lt;/code&gt; → Base64）&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title>JSON整形・圧縮ツール</title><link>https://firebird-techtalktech.com/tools/json/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/json/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="json整形圧縮ツール"&gt;JSON整形・圧縮ツール
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="tool-row"&gt;
&lt;button class="btn-primary" onclick="formatJson()"&gt;整形する&lt;/button&gt;
&lt;button onclick="minifyJson()"&gt;圧縮する&lt;/button&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;button onclick="copyOutput()"&gt;コピー&lt;/button&gt;
&lt;/div&gt;
&lt;div class="editor-row"&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;入力&lt;/label&gt;
&lt;textarea id="input" placeholder='{"key":"value"}' spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;出力&lt;/label&gt;
&lt;textarea id="output" readonly spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;p id="status"&gt;&lt;/p&gt;
&lt;p id="copy-msg" style="color:green;display:none"&gt;コピーしました！&lt;/p&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function formatJson() {
const input = document.getElementById('input').value.trim();
const status = document.getElementById('status');
if (!input) return;
try {
const obj = JSON.parse(input);
document.getElementById('output').value = JSON.stringify(obj, null, 2);
status.style.color = 'green';
status.textContent = '✅ 有効なJSONです';
} catch(e) {
status.style.color = 'red';
status.textContent = '❌ エラー: ' + e.message;
}
}
function minifyJson() {
const input = document.getElementById('input').value.trim();
const status = document.getElementById('status');
if (!input) return;
try {
const obj = JSON.parse(input);
document.getElementById('output').value = JSON.stringify(obj);
status.style.color = 'green';
status.textContent = '✅ 圧縮しました';
} catch(e) {
status.style.color = 'red';
status.textContent = '❌ エラー: ' + e.message;
}
}
function clearAll() {
document.getElementById('input').value = '';
document.getElementById('output').value = '';
document.getElementById('status').textContent = '';
}
function copyOutput() {
const v = document.getElementById('output').value;
if (!v) return;
navigator.clipboard.writeText(v).then(() =&gt; {
const msg = document.getElementById('copy-msg');
msg.style.display = 'block';
setTimeout(() =&gt; msg.style.display = 'none', 2000);
});
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 900px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.tool-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.editor-row { display: flex; gap: 1rem; }
.editor-col { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 320px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
#status { font-size: 0.9rem; min-height: 1.2em; }
@media (max-width: 600px) { .editor-row { flex-direction: column; } }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;左の入力欄にJSONを貼り付ける&lt;/li&gt;
&lt;li&gt;「整形する」でインデント付きに、「圧縮する」で1行にまとめる&lt;/li&gt;
&lt;li&gt;バリデーション結果が下に表示される&lt;/li&gt;
&lt;li&gt;「コピー」で出力をクリップボードにコピー&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="特徴"&gt;特徴
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;バリデーション付き（エラー箇所のメッセージを表示）&lt;/li&gt;
&lt;li&gt;サーバー送信なし・すべてブラウザ内で処理&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title>パスワード生成器</title><link>https://firebird-techtalktech.com/tools/password/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/password/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="パスワード生成器"&gt;パスワード生成器
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="tool-row"&gt;
&lt;label&gt;長さ: &lt;span id="len-display"&gt;16&lt;/span&gt;文字&lt;/label&gt;
&lt;input type="range" id="length" min="8" max="64" value="16" oninput="document.getElementById('len-display').textContent=this.value"&gt;
&lt;/div&gt;
&lt;div class="tool-row checkbox-row"&gt;
&lt;label&gt;&lt;input type="checkbox" id="upper" checked&gt; 大文字 (A-Z)&lt;/label&gt;
&lt;label&gt;&lt;input type="checkbox" id="lower" checked&gt; 小文字 (a-z)&lt;/label&gt;
&lt;label&gt;&lt;input type="checkbox" id="numbers" checked&gt; 数字 (0-9)&lt;/label&gt;
&lt;label&gt;&lt;input type="checkbox" id="symbols" checked&gt; 記号 (!@#$...)&lt;/label&gt;
&lt;/div&gt;
&lt;div class="tool-row"&gt;
&lt;input type="text" id="output" readonly placeholder="ここにパスワードが生成されます"&gt;
&lt;button onclick="copyPassword()"&gt;コピー&lt;/button&gt;
&lt;/div&gt;
&lt;div class="tool-row"&gt;
&lt;button class="btn-primary" onclick="generate()"&gt;生成する&lt;/button&gt;
&lt;/div&gt;
&lt;p id="copy-msg" style="color:green;display:none"&gt;コピーしました！&lt;/p&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function generate() {
const upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
const lower = 'abcdefghijklmnopqrstuvwxyz';
const nums = '0123456789';
const syms = '!@#$%^&amp;*()-_=+[]{}|;:,.&lt;&gt;?';
let chars = '';
if (document.getElementById('upper').checked) chars += upper;
if (document.getElementById('lower').checked) chars += lower;
if (document.getElementById('numbers').checked) chars += nums;
if (document.getElementById('symbols').checked) chars += syms;
if (!chars) { alert('文字種を1つ以上選択してください'); return; }
const len = parseInt(document.getElementById('length').value);
let pwd = '';
const arr = new Uint32Array(len);
crypto.getRandomValues(arr);
for (let i = 0; i &lt; len; i++) pwd += chars[arr[i] % chars.length];
document.getElementById('output').value = pwd;
}
function copyPassword() {
const v = document.getElementById('output').value;
if (!v) return;
navigator.clipboard.writeText(v).then(() =&gt; {
const msg = document.getElementById('copy-msg');
msg.style.display = 'block';
setTimeout(() =&gt; msg.style.display = 'none', 2000);
});
}
generate();
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 560px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.tool-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.checkbox-row { gap: 1rem; }
.tool-row input[type=text] { flex: 1; padding: 0.5rem; font-size: 1rem; border: 1px solid #ccc; border-radius: 4px; font-family: monospace; }
.tool-row input[type=range] { flex: 1; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.5rem; border-radius: 4px; cursor: pointer; font-size: 1rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;スライダーで長さを選ぶ（8〜64文字）&lt;/li&gt;
&lt;li&gt;使いたい文字種にチェックを入れる&lt;/li&gt;
&lt;li&gt;「生成する」をクリック&lt;/li&gt;
&lt;li&gt;「コピー」でクリップボードにコピー&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="セキュリティについて"&gt;セキュリティについて
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;乱数には &lt;code&gt;crypto.getRandomValues()&lt;/code&gt; を使用（暗号学的に安全）&lt;/li&gt;
&lt;li&gt;生成されたパスワードはサーバーに送信されません&lt;/li&gt;
&lt;li&gt;すべてブラウザ内で完結します&lt;/li&gt;
&lt;/ul&gt;</description></item></channel></rss>