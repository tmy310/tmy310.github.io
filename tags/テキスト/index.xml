<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>テキスト on firebirdテックトーク</title><link>https://firebird-techtalktech.com/tags/%E3%83%86%E3%82%AD%E3%82%B9%E3%83%88/</link><description>Recent content in テキスト on firebirdテックトーク</description><generator>Hugo -- gohugo.io</generator><language>ja</language><copyright>トミー</copyright><atom:link href="https://firebird-techtalktech.com/tags/%E3%83%86%E3%82%AD%E3%82%B9%E3%83%88/index.xml" rel="self" type="application/rss+xml"/><item><title>テキスト差分チェック</title><link>https://firebird-techtalktech.com/tools/diff/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/diff/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="テキスト差分チェック"&gt;テキスト差分チェック
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="editor-row"&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;変更前&lt;/label&gt;
&lt;textarea id="before" placeholder="変更前のテキスト" spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;変更後&lt;/label&gt;
&lt;textarea id="after" placeholder="変更後のテキスト" spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div class="tool-row"&gt;
&lt;button class="btn-primary" onclick="compare()"&gt;差分を表示&lt;/button&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;/div&gt;
&lt;div id="result" style="display:none"&gt;
&lt;label&gt;差分結果&lt;/label&gt;
&lt;div id="diff-output" class="diff-box"&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function lcs(a, b) {
const m = a.length, n = b.length;
const dp = Array.from({length: m+1}, () =&gt; new Array(n+1).fill(0));
for (let i=1;i&lt;=m;i++) for (let j=1;j&lt;=n;j++)
dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
const result = [];
let i=m, j=n;
while (i&gt;0 &amp;&amp; j&gt;0) {
if (a[i-1]===b[j-1]) { result.unshift({type:'same', val:a[i-1]}); i--;j--; }
else if (dp[i-1][j]&gt;=dp[i][j-1]) { result.unshift({type:'del', val:a[i-1]}); i--; }
else { result.unshift({type:'add', val:b[j-1]}); j--; }
}
while (i&gt;0) { result.unshift({type:'del', val:a[i-1]}); i--; }
while (j&gt;0) { result.unshift({type:'add', val:b[j-1]}); j--; }
return result;
}
function compare() {
const before = document.getElementById('before').value.split('\n');
const after = document.getElementById('after').value.split('\n');
const diff = lcs(before, after);
let html = '';
let adds=0, dels=0;
diff.forEach(d =&gt; {
const esc = d.val.replace(/&amp;/g,'&amp;amp;').replace(/&lt;/g,'&amp;lt;').replace(/&gt;/g,'&amp;gt;');
if (d.type==='del') { html += `&lt;div class="diff-del"&gt;− ${esc}&lt;/div&gt;`; dels++; }
else if (d.type==='add') { html += `&lt;div class="diff-add"&gt;+ ${esc}&lt;/div&gt;`; adds++; }
else { html += `&lt;div class="diff-same"&gt;　 ${esc}&lt;/div&gt;`; }
});
document.getElementById('diff-output').innerHTML = html || '&lt;div style="color:#888"&gt;差分なし&lt;/div&gt;';
document.getElementById('result').style.display = 'block';
}
function clearAll() {
document.getElementById('before').value = '';
document.getElementById('after').value = '';
document.getElementById('result').style.display = 'none';
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 900px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.editor-row { display: flex; gap: 1rem; }
.editor-col { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 200px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.tool-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.diff-box { font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; padding: 0.75rem; background: var(--body-background, #fff); max-height: 400px; overflow-y: auto; }
.diff-del { background: #ffeef0; color: #b31d28; white-space: pre-wrap; word-break: break-all; }
.diff-add { background: #e6ffed; color: #22863a; white-space: pre-wrap; word-break: break-all; }
.diff-same { color: #666; white-space: pre-wrap; word-break: break-all; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
#result label { font-weight: bold; font-size: 0.9rem; }
@media (max-width: 600px) { .editor-row { flex-direction: column; } }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;左に変更前、右に変更後のテキストを貼り付ける&lt;/li&gt;
&lt;li&gt;「差分を表示」をクリック&lt;/li&gt;
&lt;li&gt;赤＝削除行、緑＝追加行&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="用途例"&gt;用途例
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;設定ファイルの変更確認&lt;/li&gt;
&lt;li&gt;文章の校正・修正前後の比較&lt;/li&gt;
&lt;li&gt;コードレビューの下調べ&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title>正規表現テスター</title><link>https://firebird-techtalktech.com/tools/regex/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/regex/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="正規表現テスター"&gt;正規表現テスター
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="regex-row"&gt;
&lt;span class="slash"&gt;/&lt;/span&gt;
&lt;input type="text" id="pattern" placeholder="正規表現パターン" spellcheck="false" oninput="test()"&gt;
&lt;span class="slash"&gt;/&lt;/span&gt;
&lt;input type="text" id="flags" value="g" placeholder="flags" style="width:60px;" oninput="test()"&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;テスト文字列&lt;/label&gt;
&lt;textarea id="input" placeholder="テストするテキストを入力" spellcheck="false" oninput="test()"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;p id="status"&gt;&lt;/p&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;マッチ結果&lt;/label&gt;
&lt;div id="output" class="output-box"&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;抽出リスト&lt;/label&gt;
&lt;textarea id="matches" readonly spellcheck="false" rows="4" placeholder="マッチした文字列が表示されます"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function test() {
const pattern = document.getElementById('pattern').value;
const flags = document.getElementById('flags').value;
const input = document.getElementById('input').value;
const status = document.getElementById('status');
const output = document.getElementById('output');
const matchesEl = document.getElementById('matches');
if (!pattern) {
output.textContent = input;
status.textContent = '';
matchesEl.value = '';
return;
}
try {
const re = new RegExp(pattern, flags);
const matches = [...input.matchAll(new RegExp(pattern, flags.includes('g') ? flags : flags + 'g'))];
status.style.color = matches.length &gt; 0 ? 'green' : '#888';
status.textContent = matches.length &gt; 0 ? `✅ ${matches.length} 件マッチ` : '⚠️ マッチなし';
matchesEl.value = matches.map(m =&gt; m[0]).join('\n');
// ハイライト
const escaped = input.replace(/&amp;/g,'&amp;amp;').replace(/&lt;/g,'&amp;lt;').replace(/&gt;/g,'&amp;gt;');
const highlighted = escaped.replace(new RegExp(pattern.replace(/[.*+?^${}()|[\]\\]/g, '\\$&amp;'), flags),
m =&gt; `&lt;mark&gt;${m}&lt;/mark&gt;`);
output.innerHTML = highlighted;
} catch(e) {
status.style.color = 'red';
status.textContent = '❌ ' + e.message;
output.textContent = input;
matchesEl.value = '';
}
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 700px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.regex-row { display: flex; align-items: center; gap: 0.4rem; }
.regex-row input:first-of-type { flex: 1; }
.slash { font-size: 1.4rem; color: #888; font-family: monospace; }
.regex-row input { padding: 0.5rem; font-family: monospace; font-size: 0.95rem; border: 1px solid #ccc; border-radius: 4px; }
.editor-col { display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.output-box { min-height: 80px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; background: var(--body-background, #fff); white-space: pre-wrap; word-break: break-all; line-height: 1.8; }
.output-box mark { background: #ffe066; color: #333; border-radius: 2px; }
#status { font-size: 0.9rem; min-height: 1.2em; }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;正規表現パターンを入力&lt;/li&gt;
&lt;li&gt;フラグを設定（&lt;code&gt;g&lt;/code&gt;=全体, &lt;code&gt;i&lt;/code&gt;=大小文字無視, &lt;code&gt;m&lt;/code&gt;=複数行）&lt;/li&gt;
&lt;li&gt;テスト文字列を入力するとリアルタイムでマッチ箇所がハイライト&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="用途例"&gt;用途例
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;メールアドレス・電話番号の検証パターン確認&lt;/li&gt;
&lt;li&gt;ログからの情報抽出&lt;/li&gt;
&lt;li&gt;テキスト置換の事前確認&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title>文字数カウンター</title><link>https://firebird-techtalktech.com/tools/text-counter/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/text-counter/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="文字数カウンター"&gt;文字数カウンター
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;テキスト入力&lt;/label&gt;
&lt;textarea id="input" placeholder="ここにテキストを入力してください" spellcheck="false" oninput="count()"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;div class="stats-grid"&gt;
&lt;div class="stat-box"&gt;&lt;div class="stat-num" id="chars"&gt;0&lt;/div&gt;&lt;div class="stat-label"&gt;文字数（スペース含む）&lt;/div&gt;&lt;/div&gt;
&lt;div class="stat-box"&gt;&lt;div class="stat-num" id="chars-no-space"&gt;0&lt;/div&gt;&lt;div class="stat-label"&gt;文字数（スペース除く）&lt;/div&gt;&lt;/div&gt;
&lt;div class="stat-box"&gt;&lt;div class="stat-num" id="lines"&gt;0&lt;/div&gt;&lt;div class="stat-label"&gt;行数&lt;/div&gt;&lt;/div&gt;
&lt;div class="stat-box"&gt;&lt;div class="stat-num" id="bytes"&gt;0&lt;/div&gt;&lt;div class="stat-label"&gt;バイト数（UTF-8）&lt;/div&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function count() {
const text = document.getElementById('input').value;
document.getElementById('chars').textContent = text.length;
document.getElementById('chars-no-space').textContent = text.replace(/\s/g, '').length;
document.getElementById('lines').textContent = text === '' ? 0 : text.split('\n').length;
document.getElementById('bytes').textContent = new TextEncoder().encode(text).length;
}
function clearAll() {
document.getElementById('input').value = '';
count();
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 700px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.editor-col { display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 220px; padding: 0.75rem; font-size: 0.95rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
.stat-box { background: var(--body-background, #fff); border: 1px solid #e0e0e0; border-radius: 6px; padding: 0.75rem 1rem; text-align: center; }
.stat-num { font-size: 1.8rem; font-weight: bold; color: #e25555; }
.stat-label { font-size: 0.8rem; color: #888; margin-top: 0.2rem; }
button { align-self: flex-start; padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;p&gt;テキストを入力するとリアルタイムでカウントされます。&lt;/p&gt;</description></item></channel></rss>