<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>差分 on firebirdテックトーク</title><link>https://firebird-techtalktech.com/tags/%E5%B7%AE%E5%88%86/</link><description>Recent content in 差分 on firebirdテックトーク</description><generator>Hugo -- gohugo.io</generator><language>ja</language><copyright>トミー</copyright><atom:link href="https://firebird-techtalktech.com/tags/%E5%B7%AE%E5%88%86/index.xml" rel="self" type="application/rss+xml"/><item><title>テキスト差分チェック</title><link>https://firebird-techtalktech.com/tools/diff/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/diff/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="テキスト差分チェック"&gt;テキスト差分チェック
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="editor-row"&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;変更前&lt;/label&gt;
&lt;textarea id="before" placeholder="変更前のテキスト" spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;変更後&lt;/label&gt;
&lt;textarea id="after" placeholder="変更後のテキスト" spellcheck="false"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;div class="tool-row"&gt;
&lt;button class="btn-primary" onclick="compare()"&gt;差分を表示&lt;/button&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;/div&gt;
&lt;div id="result" style="display:none"&gt;
&lt;label&gt;差分結果&lt;/label&gt;
&lt;div id="diff-output" class="diff-box"&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function lcs(a, b) {
const m = a.length, n = b.length;
const dp = Array.from({length: m+1}, () =&gt; new Array(n+1).fill(0));
for (let i=1;i&lt;=m;i++) for (let j=1;j&lt;=n;j++)
dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
const result = [];
let i=m, j=n;
while (i&gt;0 &amp;&amp; j&gt;0) {
if (a[i-1]===b[j-1]) { result.unshift({type:'same', val:a[i-1]}); i--;j--; }
else if (dp[i-1][j]&gt;=dp[i][j-1]) { result.unshift({type:'del', val:a[i-1]}); i--; }
else { result.unshift({type:'add', val:b[j-1]}); j--; }
}
while (i&gt;0) { result.unshift({type:'del', val:a[i-1]}); i--; }
while (j&gt;0) { result.unshift({type:'add', val:b[j-1]}); j--; }
return result;
}
function compare() {
const before = document.getElementById('before').value.split('\n');
const after = document.getElementById('after').value.split('\n');
const diff = lcs(before, after);
let html = '';
let adds=0, dels=0;
diff.forEach(d =&gt; {
const esc = d.val.replace(/&amp;/g,'&amp;amp;').replace(/&lt;/g,'&amp;lt;').replace(/&gt;/g,'&amp;gt;');
if (d.type==='del') { html += `&lt;div class="diff-del"&gt;− ${esc}&lt;/div&gt;`; dels++; }
else if (d.type==='add') { html += `&lt;div class="diff-add"&gt;+ ${esc}&lt;/div&gt;`; adds++; }
else { html += `&lt;div class="diff-same"&gt;　 ${esc}&lt;/div&gt;`; }
});
document.getElementById('diff-output').innerHTML = html || '&lt;div style="color:#888"&gt;差分なし&lt;/div&gt;';
document.getElementById('result').style.display = 'block';
}
function clearAll() {
document.getElementById('before').value = '';
document.getElementById('after').value = '';
document.getElementById('result').style.display = 'none';
}
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 900px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.editor-row { display: flex; gap: 1rem; }
.editor-col { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 200px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.tool-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.diff-box { font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; padding: 0.75rem; background: var(--body-background, #fff); max-height: 400px; overflow-y: auto; }
.diff-del { background: #ffeef0; color: #b31d28; white-space: pre-wrap; word-break: break-all; }
.diff-add { background: #e6ffed; color: #22863a; white-space: pre-wrap; word-break: break-all; }
.diff-same { color: #666; white-space: pre-wrap; word-break: break-all; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
#result label { font-weight: bold; font-size: 0.9rem; }
@media (max-width: 600px) { .editor-row { flex-direction: column; } }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;左に変更前、右に変更後のテキストを貼り付ける&lt;/li&gt;
&lt;li&gt;「差分を表示」をクリック&lt;/li&gt;
&lt;li&gt;赤＝削除行、緑＝追加行&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="用途例"&gt;用途例
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;設定ファイルの変更確認&lt;/li&gt;
&lt;li&gt;文章の校正・修正前後の比較&lt;/li&gt;
&lt;li&gt;コードレビューの下調べ&lt;/li&gt;
&lt;/ul&gt;</description></item></channel></rss>