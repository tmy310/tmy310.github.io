<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>UUID on firebirdテックトーク</title><link>https://firebird-techtalktech.com/tags/uuid/</link><description>Recent content in UUID on firebirdテックトーク</description><generator>Hugo -- gohugo.io</generator><language>ja</language><copyright>トミー</copyright><atom:link href="https://firebird-techtalktech.com/tags/uuid/index.xml" rel="self" type="application/rss+xml"/><item><title>UUID生成器</title><link>https://firebird-techtalktech.com/tools/uuid/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://firebird-techtalktech.com/tools/uuid/</guid><description>&lt;div class="tool-container"&gt;
&lt;h2 id="uuid生成器"&gt;UUID生成器
&lt;/h2&gt;&lt;div class="tool-box"&gt;
&lt;div class="tool-row"&gt;
&lt;label&gt;生成数：&lt;input type="number" id="count" value="1" min="1" max="100" style="width:60px;margin-left:0.5rem;padding:0.3rem;border:1px solid #ccc;border-radius:4px;"&gt;&lt;/label&gt;
&lt;button class="btn-primary" onclick="generate()"&gt;生成する&lt;/button&gt;
&lt;button onclick="copyOutput()"&gt;全コピー&lt;/button&gt;
&lt;button onclick="clearAll()"&gt;クリア&lt;/button&gt;
&lt;/div&gt;
&lt;div class="editor-col"&gt;
&lt;label&gt;生成されたUUID&lt;/label&gt;
&lt;textarea id="output" readonly spellcheck="false" placeholder="ここにUUIDが表示されます"&gt;&lt;/textarea&gt;
&lt;/div&gt;
&lt;p id="copy-msg" style="color:green;display:none"&gt;コピーしました！&lt;/p&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function generate() {
const count = Math.min(100, Math.max(1, parseInt(document.getElementById('count').value) || 1));
const uuids = [];
for (let i = 0; i &lt; count; i++) {
uuids.push(crypto.randomUUID());
}
document.getElementById('output').value = uuids.join('\n');
}
function clearAll() {
document.getElementById('output').value = '';
}
function copyOutput() {
const v = document.getElementById('output').value;
if (!v) return;
navigator.clipboard.writeText(v).then(() =&gt; {
const msg = document.getElementById('copy-msg');
msg.style.display = 'block';
setTimeout(() =&gt; msg.style.display = 'none', 2000);
});
}
generate();
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 600px; margin: 2rem auto; }
.tool-box { background: var(--card-background, #f9f9f9); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.tool-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.editor-col { display: flex; flex-direction: column; gap: 0.4rem; }
.editor-col label { font-weight: bold; font-size: 0.9rem; }
textarea { width: 100%; height: 200px; padding: 0.75rem; font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 4px; resize: vertical; box-sizing: border-box; }
.btn-primary { background: #e25555; color: #fff; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
.btn-primary:hover { background: #c73e3e; }
button { padding: 0.5rem 1rem; border-radius: 4px; border: 1px solid #ccc; cursor: pointer; }
&lt;/style&gt;
&lt;hr&gt;
&lt;h2 id="使い方"&gt;使い方
&lt;/h2&gt;&lt;ol&gt;
&lt;li&gt;生成数を入力（1〜100）&lt;/li&gt;
&lt;li&gt;「生成する」をクリック&lt;/li&gt;
&lt;li&gt;「全コピー」でクリップボードにコピー&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="用途例"&gt;用途例
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;データベースのレコードID生成&lt;/li&gt;
&lt;li&gt;APIトークン・セッションID&lt;/li&gt;
&lt;li&gt;テスト用ダミーデータ&lt;/li&gt;
&lt;/ul&gt;</description></item></channel></rss>